# === PRODUCTION ENVIRONMENT ===
# Copy to Vercel Environment Variables (Production scope)

DATABASE_URI=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/remedes_mamie_prod?sslmode=require
PAYLOAD_SECRET=GENERATE-64-CHAR-RANDOM-SECRET-FOR-PRODUCTION
NEXT_PUBLIC_SITE_URL=https://remedes-mamie.com
NODE_ENV=production

# Pipeline IA
AI_PIPELINE_API_KEYS=["prod-key-sha256-hash-here"]
AI_PIPELINE_HMAC_SECRET=GENERATE-32-CHAR-RANDOM-SECRET-FOR-PRODUCTION

# WORM backup (production: local persistent volume)
WORM_BACKUP_DIR=/data/worm-backups

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=remedes-mamie.com
